{
  "name": "jawad-khan-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"SERVER,CLIENT\" --prefix-colors \"cyan,magenta\" \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npx vite",
    "start": "node server/index.js",
    "build": "cd client && npx vite build",
    "build:client": "cd client && npx vite build"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
